ng Difference-Income Account","843003":"Round Off Salary Differences","851001":"Worker Welfare Fund","852001":"Worker Profit Participation Fund","853001":"Zakat to FF & other Donees","861001":"Current tax","861002":"Prior Tax","862001":"Current Deffered Tax","862002":"Prior Deffered Tax","870000":"Exteranal services CS","990001":"Real-Time Integration FI>CO - Allocations","990002":"Real-Time Integration FI>CO - Order Settlements","990003":"Real-Time Integration FI>CO - Actual Price Calc","990004":"Real-Time Integration FI>CO - Repostings","991002":"Technical A/C for Doc Split in HR for FI - PR #","993001":"Initial Stock Upload Account","993002":"Initial Upload FI","999911":"External Settlement Internal Orders"};

const EXP = { cur: null, prev: null, result: null };

function fmtNum(n) {
  if (n === null || n === undefined || n === "" || !isFinite(n)) return "";
  return Number(n).toLocaleString(undefined, { maximumFractionDigits: 2 });
}
function fmtPct(n) {
  if (n === null || n === undefined || !isFinite(n)) return "";
  return (n * 100).toFixed(2) + "%";
}
function glKey(v) {
  if (v === null || v === undefined) return "";
  return String(v).replace(/\.0+$/, "").trim();
}

function expReadCleaned(aoa) {
  let hr = -1, glC = -1, amtC = -1;
  for (let r = 0; r < Math.min(10, aoa.length); r++) {
    const row = (aoa[r] || []).map(v => String(v ?? "").toLowerCase().trim());
    const gi = row.findIndex(x => x.includes("gl"));
    const ai = row.findIndex(x => x === "amount" || x.includes("amount"));
    if (gi >= 0 && ai >= 0) { hr = r; glC = gi; amtC = ai; break; }
  }
  if (hr < 0) throw new Error("Could not find 'GL Account' and 'Amount' columns. Use a Stage-1 cleaned sheet.");
  const sums = {};
  let total = 0;
  for (let r = hr + 1; r < aoa.length; r++) {
    const row = aoa[r] || [];
    const g = glKey(row[glC]);
    const amt = Number(String(row[amtC] ?? "").replace(/,/g, "")) || 0;
    if (!g || amt === 0) continue;
    sums[g] = (sums[g] || 0) + amt;
    total += amt;
  }
  return { sums, total };
}

function runExpenseAnalysis() {
  if (!EXP.cur) throw new Error("Upload the current-period cleaned sheet.");
  const cur  = expReadCleaned(EXP.cur.rows);
  const prev = EXP.prev ? expReadCleaned(EXP.prev.rows) : { sums: {}, total: 0 };

  const allGLs = Array.from(new Set([...Object.keys(cur.sums), ...Object.keys(prev.sums)]));
  allGLs.sort((a, b) => (Number(a) || 0) - (Number(b) || 0) || a.localeCompare(b));

  const totalCur = cur.total, totalPrev = prev.total;

  const rows = allGLs.map(g => {
    const c = cur.sums[g] || 0;
    const p = prev.sums[g] || 0;
    const diff = c - p;
    return {
      "GL": g,
      "Account description": GL_MAP[g] || "(description not found)",
      "Total expenses (Rs.) — Current": c,
      "Vertical analysis % — Current": totalCur ? c / totalCur : 0,
      "Total expenses (Rs.) — Previous": p,
      "Vertical analysis % — Previous": totalPrev ? p / totalPrev : 0,
      "Difference in Amount": diff,
      "% Difference": p ? diff / p : (c ? 1 : 0),
    };
  });

  rows.push({
    "GL": "",
    "Account description": "Total expenses for the Quarter",
    "Total expenses (Rs.) — Current": totalCur,
    "Vertical analysis % — Current": totalCur ? 1 : 0,
    "Total expenses (Rs.) — Previous": totalPrev,
    "Vertical analysis % — Previous": totalPrev ? 1 : 0,
    "Difference in Amount": totalCur - totalPrev,
    "% Difference": totalPrev ? (totalCur - totalPrev) / totalPrev : 0,
  });

  EXP.result = {
    rows,
    curLabel:  ($("#expLabelCur").val()  || "Current Period").trim(),
    prevLabel: ($("#expLabelPrev").val() || "Previous Period").trim(),
    summary:
      `${allGLs.length} GL account(s) across both sheets. ` +
      `Current total: Rs. ${fmtNum(totalCur)}. Previous total: Rs. ${fmtNum(totalPrev)}. ` +
      `Difference: Rs. ${fmtNum(totalCur - totalPrev)} (${fmtPct(totalPrev ? (totalCur - totalPrev)/totalPrev : 0)}).`,
  };
}

const EXP_PCT = new Set(["Vertical analysis % — Current","Vertical analysis % — Previous","% Difference"]);
const EXP_MONEY = new Set(["Total expenses (Rs.) — Current","Total expenses (Rs.) — Previous","Difference in Amount"]);

function renderExpenseResults() {
  if (!EXP.result) return;
  $("#expResultsCard").removeClass("hidden");
  if (typeof revealNow==="function") revealNow("#expResultsCard");
  $("#expSummary").text(EXP.result.summary);
  const rows = EXP.result.rows;
  const cols = Object.keys(rows[0]);
  const $c = $("#expResultsTable").empty();
  const $tbl = $('<table class="w-full text-sm border-collapse"></table>');
  const head = cols.map(c => c
      .replace("— Current", "(" + EXP.result.curLabel + ")")
      .replace("— Previous", "(" + EXP.result.prevLabel + ")"));
  $tbl.append(`<thead><tr>${head.map(c =>
    `<th class="text-left px-3 py-2 font-semibold whitespace-nowrap">${$("<div/>").text(c).html()}</th>`).join("")}</tr></thead>`);
  const $tb = $("<tbody></tbody>");
  rows.forEach((r, i) => {
    const isTotal = i === rows.length - 1;
    const rowCls = isTotal ? "font-bold border-t-2 border-slate-300 bg-yellow-50"
                           : (i % 2 ? "row-odd" : "row-even");
    $tb.append(`<tr class="${rowCls}">${cols.map(col => {
      let v = r[col];
      if (EXP_PCT.has(col)) return `<td class="px-3 py-1.5 text-right">${fmtPct(v)}</td>`;
      if (EXP_MONEY.has(col)) {
        const cls = (Number(v) < 0) ? "text-red-700" : "";
        return `<td class="px-3 py-1.5 text-right ${cls}">${fmtNum(v)}</td>`;
      }
      return `<td class="px-3 py-1.5">${$("<div/>").text(v ?? "").html()}</td>`;
    }).join("")}</tr>`);
  });
  $tbl.append($tb);
  $c.append($tbl);
}

async function expLoad(slot, file, badgeSel) {
  try {
    const buf = await file.arrayBuffer();
    const wb = XLSX.read(buf, { cellDates: true });
    const ws = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: null });
    EXP[slot] = { rows, fileName: file.name };
    $(badgeSel).text("📄  " + file.name);
    $("#expRunBtn").prop("disabled", !EXP.cur);
    $("#expExportBtn").prop("disabled", true);
    $("#expResultsCard").addClass("hidden");
  } catch (err) {
    console.error(err);
    alert("Failed to read file: " + err.message);
  }
}

$("#expFileCur").on("change",  e => { if (e.target.files[0]) expLoad("cur",  e.target.files[0], "#expBadgeCur"); });
$("#expFilePrev").on("change", e => { if (e.target.files[0]) expLoad("prev", e.target.files[0], "#expBadgePrev"); });

$("#expRunBtn").on("click", function () {
  try {
    runExpenseAnalysis();
    renderExpenseResults();
    $("#expExportBtn").prop("disabled", false);
  } catch (e) { console.error(e); alert("Analysis failed: " + e.message); }
});

$("#expExportBtn").on("click", function () {
  if (!EXP.result) return;
  const L = EXP.result;
  const aoa = [
    ["Analysis and Comparison of Petty cash Expenses"],
    [],
    ["GL", "Account description", L.curLabel, "", L.prevLabel, "", "Comparable Quarter Difference", ""],
    ["", "", "Total expenses (Rs.)", "Vertical analysis %", "Total expenses (Rs.)", "Vertical analysis %", "Difference in Amount", "% Difference"],
  ];
  L.rows.forEach(r => {
    aoa.push([
      r["GL"], r["Account description"],
      r["Total expenses (Rs.) — Current"], r["Vertical analysis % — Current"],
      r["Total expenses (Rs.) — Previous"], r["Vertical analysis % — Previous"],
      r["Difference in Amount"], r["% Difference"],
    ]);
  });
  const ws = XLSX.utils.aoa_to_sheet(aoa);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, "Expense Analysis");
  const stamp = new Date().toISOString().replace(/[-T:.Z]/g, "").slice(0, 12);
  XLSX.writeFile(wb, `Expense_Analysis_${stamp}.xlsx`);
});

// ---------------- Cash Journal Cleaner ----------------
// Two slots: each = { rows: <raw aoa>, fileName, result }
const CJ = { slots: [null, null], active: 0 };

const CJ_OUT_COLS = [
  "Document Number", "Text", "Posting Date", "Doc Date",
  "Amount", "Cost Center", "GL Account", "Order", "Business Area"
];

function cjFindHeaders(aoa) {
  let hdr1 = -1, hdr2 = -1;
  for (let r = 0; r < Math.min(25, aoa.length); r++) {
    const row = (aoa[r] || []).map(v => String(v ?? "").toLowerCase().trim());
    if (hdr1 < 0 && row.includes("document number")) hdr1 = r;
    if (hdr1 >= 0 && row.includes("customer")) { hdr2 = r; break; }
  }
  return { hdr1, hdr2 };
}

function cjColOf(aoa, rowIdx, labels) {
  if (rowIdx < 0) return -1;
  const row = aoa[rowIdx] || [];
  for (let c = 0; c < row.length; c++) {
    const v = String(row[c] ?? "").trim().toLowerCase();
    for (const l of labels) if (v === l.toLowerCase()) return c;
  }
  return -1;
}

function cjIsEmpty(v) {
  if (v === null || v === undefined) return true;
  if (typeof v === "string") return v.trim() === "";
  return false;
}

function cjFmtDate(v) {
  if (v == null || v === "") return "";
  if (v instanceof Date) {
    const d = String(v.getDate()).padStart(2, "0");
    const m = String(v.getMonth() + 1).padStart(2, "0");
    return `${d}.${m}.${v.getFullYear()}`;
  }
  return String(v);
}

function runCashJournalCleaning(aoa) {
  const { hdr1, hdr2 } = cjFindHeaders(aoa);
  if (hdr1 < 0 || hdr2 < 0)
    throw new Error("Could not find the 'Document Number' / 'Customer' header rows. Is this a raw FBCJ export?");

  const cols = {
    doc:  cjColOf(aoa, hdr1, ["Document Number"]),
    pstg: cjColOf(aoa, hdr1, ["Pstng Date", "Posting Date"]),
    docd: cjColOf(aoa, hdr1, ["Doc. Date", "Doc Date"]),
    text: cjColOf(aoa, hdr2, ["Text for item", "Text"]),
    recv: cjColOf(aoa, hdr2, ["Receipts"]),
    exp:  cjColOf(aoa, hdr2, ["Expenses"]),
    cc:   cjColOf(aoa, hdr2, ["Cost Ctr", "Cost Center"]),
    gl:   cjColOf(aoa, hdr2, ["G/L acct", "GL Account", "G/L Account"]),
    ord:  cjColOf(aoa, hdr2, ["Order"]),
    ba:   cjColOf(aoa, hdr2, ["BusA", "Business Area"]),
  };

  const records = [];
  let droppedZero = 0, droppedDQ = 0;
  let i = hdr2 + 1;
  while (i < aoa.length) {
    const row = aoa[i] || [];
    const doc = row[cols.doc];
    if (!cjIsEmpty(doc)) {
      const pstg = row[cols.pstg];
      const docd = row[cols.docd];
      // find next row with amount or text
      let j = i + 1;
      while (j < aoa.length) {
        const nr = aoa[j] || [];
        const ar = nr[cols.recv];
        const ae = nr[cols.exp];
        const tx = nr[cols.text];
        if (!cjIsEmpty(ar) || !cjIsEmpty(ae) || !cjIsEmpty(tx)) {
          const receipts = Number(ar) || 0;
          const expenses = Number(ae) || 0;
          const amount   = expenses !== 0 ? expenses : receipts;  // petty cash: amount = expenses; fallback to receipts
          const cc       = nr[cols.cc];
          const gl       = nr[cols.gl];
          const ord      = nr[cols.ord];
          const ba       = nr[cols.ba];

          if (amount === 0) {
            droppedZero++;
          } else if (cjIsEmpty(cc) && cjIsEmpty(ord) && cjIsEmpty(ba)) {
            droppedDQ++;
          } else {
            records.push({
              "Document Number": doc,
              "Text":            tx ?? "",
              "Posting Date":    cjFmtDate(pstg),
              "Doc Date":        cjFmtDate(docd),
              "Amount":          amount,
              "Cost Center":     cc ?? "",
              "GL Account":      gl ?? "",
              "Order":           ord ?? "",
              "Business Area":   ba ?? "",
            });
          }
          i = j + 1;
          break;
        }
        j++;
      }
      if (j >= aoa.length) break;
    } else {
      i++;
    }
  }

  const total = records.reduce((s, r) => s + (Number(r.Amount) || 0), 0);
  const rowsOut = records.slice();
  rowsOut.push({
    "Document Number": "",
    "Text": "",
    "Posting Date": "",
    "Doc Date": "",
    "Amount": total,
    "Cost Center": "",
    "GL Account": "",
    "Order": "",
    "Business Area": "",
  });

  return {
    rows: rowsOut,
    summary:
      `${records.length} transaction(s) cleaned. ` +
      `Dropped ${droppedZero} zero-amount row(s) and ${droppedDQ} row(s) ` +
      `missing master data. Grand total: ${total.toLocaleString(undefined, { maximumFractionDigits: 2 })}.`,
  };
}

function cjRenderTabs() {
  const $tabs = $("#cjTabs").empty();
  let shown = 0;
  CJ.slots.forEach((slot, idx) => {
    if (!slot || !slot.result) return;
    shown++;
    const label = (slot.fileName || `File ${idx + 1}`).replace(/\.[^.]+$/, "");
    $tabs.append(
      `<button class="tab-btn ${idx === CJ.active ? "active" : ""}" data-cjtab="${idx}"
               style="color:${idx === CJ.active ? "#ffd84d" : "#cfe1f5"};
                      border-bottom:2px solid ${idx === CJ.active ? "#ffd84d" : "transparent"};
                      padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;">
         ${label}
       </button>`);
  });
  $tabs.toggle(shown > 1);
  $tabs.off("click").on("click", ".tab-btn", function () {
    CJ.active = Number($(this).data("cjtab"));
    cjRenderTabs();
    renderCashJournalResults();
  });
}

function renderCashJournalResults() {
  const slot = CJ.slots[CJ.active];
  if (!slot || !slot.result) return;
  $("#cjResultsCard").removeClass("hidden");
  if (typeof revealNow==="function") revealNow("#cjResultsCard");
  $("#cjSummary").text(slot.result.summary);

  const rows = slot.result.rows;
  const $c = $("#cjResultsTable").empty();
  const $tbl = $(`<table class="w-full text-sm border-collapse"></table>`);
  $tbl.append(`<thead><tr>${CJ_OUT_COLS.map(c =>
    `<th class="text-left px-3 py-2 font-semibold whitespace-nowrap">${c}</th>`).join("")}</tr></thead>`);
  const $tb = $("<tbody></tbody>");
  rows.forEach((r, i) => {
    const isTotal = i === rows.length - 1;
    const rowCls = isTotal
      ? "font-bold border-t-2 border-slate-300 bg-yellow-50"
      : (i % 2 ? "row-odd" : "row-even");
    $tb.append(`<tr class="${rowCls}">${CJ_OUT_COLS.map(col => {
      let v = r[col];
      if (col === "Amount") {
        const n = Number(v) || 0;
        return `<td class="px-3 py-1.5 text-right whitespace-nowrap">${
          n === 0 && !isTotal ? "" : n.toLocaleString(undefined, { maximumFractionDigits: 2 })
        }</td>`;
      }
      return `<td class="px-3 py-1.5">${$("<div/>").text(v ?? "").html()}</td>`;
    }).join("")}</tr>`);
  });
  $tbl.append($tb);
  $c.append($tbl);
}

async function cjLoadSlot(slotIdx, file, badgeSel) {
  try {
    const buf = await file.arrayBuffer();
    const wb = XLSX.read(buf, { cellDates: true });
    const ws = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: null });
    CJ.slots[slotIdx] = { rows, fileName: file.name, result: null };
    $(badgeSel).text("📄  " + file.name);
    $("#cjRunBtn").prop("disabled", !(CJ.slots[0] || CJ.slots[1]));
    $("#cjExportBtn").prop("disabled", true);
    $("#cjResultsCard").addClass("hidden");
  } catch (err) {
    console.error(err);
    alert("Failed to read file: " + err.message);
  }
}

$("#cjFileInput1").on("change", function (e) {
  if (e.target.files[0]) cjLoadSlot(0, e.target.files[0], "#cjFileBadge1");
});
$("#cjFileInput2").on("change", function (e) {
  if (e.target.files[0]) cjLoadSlot(1, e.target.files[0], "#cjFileBadge2");
});

$("#cjRunBtn").on("click", function () {
  let firstWith = -1;
  try {
    CJ.slots.forEach((slot, idx) => {
      if (slot && slot.rows && slot.rows.length) {
        slot.result = runCashJournalCleaning(slot.rows);
        if (firstWith < 0) firstWith = idx;
      }
    });
    if (firstWith < 0) { alert("Upload at least one file first."); return; }
    CJ.active = firstWith;
    cjRenderTabs();
    renderCashJournalResults();
    $("#cjExportBtn").prop("disabled", false);
  } catch (e) {
    console.error(e);
    alert("Cleaning failed: " + e.message);
  }
});

// Bridge Stage 1 → Stage 2: pass cleaned sheets straight into Expense Analysis
$("#cjToExpenseBtn").on("click", function () {
  const cur  = CJ.slots[0];
  const prev = CJ.slots[1];
  if (!cur || !cur.result) {
    alert("Clean at least File 1 (current year) first.");
    return;
  }
  // build aoa (header + rows) from each cleaned result for the EXP reader
  const toAoa = (slot) => {
    if (!slot || !slot.result) return null;
    const body = slot.result.rows
      .filter((_, i) => i !== slot.result.rows.length - 1) // drop the grand-total row
      .map(r => CJ_OUT_COLS.map(c => r[c]));
    return { rows: [CJ_OUT_COLS, ...body], fileName: slot.fileName };
  };
  EXP.cur  = toAoa(cur);
  EXP.prev = toAoa(prev);

  // prefill period labels from file names if empty
  if (!$("#expLabelCur").val()  && cur)  $("#expLabelCur").val((cur.fileName  || "").replace(/\.[^.]+$/, ""));
  if (!$("#expLabelPrev").val() && prev) $("#expLabelPrev").val((prev.fileName || "").replace(/\.[^.]+$/, ""));

  // reflect in the Stage-2 upload badges
  $("#expBadgeCur").text("📄  " + (cur.fileName  || "From Stage 1"));
  $("#expBadgePrev").text(prev ? "📄  " + (prev.fileName || "From Stage 1") : "No file loaded");
  $("#expRunBtn").prop("disabled", false);

  // navigate to Stage 2 and run immediately
  location.hash = "#/expense-analysis";
  setTimeout(() => {
    try {
      runExpenseAnalysis();
      renderExpenseResults();
      $("#expExportBtn").prop("disabled", false);
    } catch (e) { console.error(e); alert("Analysis failed: " + e.message); }
  }, 60);
});

$("#cjExportBtn").on("click", function () {
  const done = CJ.slots.filter(s => s && s.result);
  if (!done.length) return;
  const stamp = new Date().toISOString().replace(/[-T:.Z]/g, "").slice(0, 12);

  if (done.length === 1) {
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb,
      XLSX.utils.json_to_sheet(done[0].result.rows, { header: CJ_OUT_COLS }), "Cleaned");
    const base = (done[0].fileName || "FBCJ").replace(/\.[^.]+$/, "");
    XLSX.writeFile(wb, `${base}_cleaned_${stamp}.xlsx`);
  } else {
    // both years → one workbook, one sheet per file
    const wb = XLSX.utils.book_new();
    CJ.slots.forEach((slot, idx) => {
      if (!slot || !slot.result) return;
      const name = ((slot.fileName || `File ${idx + 1}`).replace(/\.[^.]+$/, "")).slice(0, 28) || `File ${idx + 1}`;
      XLSX.utils.book_append_sheet(wb,
        XLSX.utils.json_to_sheet(slot.result.rows, { header: CJ_OUT_COLS }), name.slice(0, 31));
    });
    XLSX.writeFile(wb, `Cash_Journal_Cleaned_${stamp}.xlsx`);
  }
});

// ---------------- CS Notifications Verification ----------------
const CS = { von: null, zcs: null, result: null, activeTab: "verified" };

// derived columns placed FIRST (from ZCS04 + computed), then the VON row follows
const CS_DERIVED_COLS = [
  "Order", "Notification", "Notif Date", "DOP", "Diff",
  "Batch #", "Description", "Division", "Name"
];

function csNorm(v) { return v === null || v === undefined ? "" : String(v).replace(/\.0+$/, "").trim(); }

function csHeaderRow(aoa, mustHave) {
  for (let r = 0; r < Math.min(8, aoa.length); r++) {
    const row = (aoa[r] || []).map(x => String(x ?? "").toLowerCase().trim());
    if (mustHave.every(h => row.some(c => c.includes(h)))) return r;
  }
  return 0;
}
function csColIndex(headerRow, labels) {
  const row = (headerRow || []).map(x => String(x ?? "").toLowerCase().trim());
  for (const l of labels) {
    const i = row.findIndex(c => c === l.toLowerCase());
    if (i >= 0) return i;
  }
  for (const l of labels) {
    const i = row.findIndex(c => c.includes(l.toLowerCase()));
    if (i >= 0) return i;
  }
  return -1;
}
function csToDate(v) {
  if (v instanceof Date) return v;
  if (v == null || v === "") return null;
  const d = new Date(v);
  return isNaN(d) ? null : d;
}
function csFmtDate(d) {
  if (!(d instanceof Date) || isNaN(d)) return "";
  const dd = String(d.getDate()).padStart(2, "0");
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  return `${dd}.${mm}.${d.getFullYear()}`;
}
// format a raw VON cell for display (dates -> dd.mm.yyyy, else trimmed string)
function csCell(v) {
  if (v instanceof Date) return csFmtDate(v);
  if (v === null || v === undefined) return "";
  return String(v).replace(/\.0+$/, "").trim();
}

// warranty period (years) from VON material description
function csWarranty(desc) {
  const d = String(desc || "").toUpperCase();
  if (d.includes("COMP")) return [10, "Compressor"];
  if (d.includes("MOTOR") && (d.includes("WM") || d.includes("WASH"))) return [10, "WM Motor"];
  if (d.includes("PCB")) return [4, "PCB Kit"];
  if (d.includes("LED") && d.includes("PANEL")) return [2, "LED Panel"];
  if (d.includes("PANEL")) return [2, "Panel"];
  if (d.includes("LED") && (d.includes("BOARD") || d.includes("BRD"))) return [1, "LED Board"];
  return [1, "Other (1yr)"];
}

function runCsVerification() {
  if (!CS.von || !CS.zcs) throw new Error("Upload both VON and ZCS04 files.");
  CS._cols = null;

  // ---- VON ----
  const va = CS.von;
  const vh = csHeaderRow(va, ["order", "movement type"]);
  const vHead = va[vh];
  const vHeaders = (vHead || []).map((h, i) => {
    const name = String(h ?? "").trim();
    return name || `Column ${i + 1}`;
  });
  const vc = {
    order: csColIndex(vHead, ["Order"]),
    mv:    csColIndex(vHead, ["Movement Type"]),
    part:  csColIndex(vHead, ["Material Description"]),
  };
  if (vc.order < 0 || vc.mv < 0) throw new Error("VON: couldn't find Order / Movement Type columns.");

  // ---- ZCS04 ----
  const za = CS.zcs;
  const zh = csHeaderRow(za, ["service order", "notification"]);
  const zHead = za[zh];
  const zc = {
    so:    csColIndex(zHead, ["Service Order No.", "Service Order"]),
    notif: csColIndex(zHead, ["Notification"]),
    ndate: csColIndex(zHead, ["Date"]),
    pdate: csColIndex(zHead, ["Date of Purchase - S9", "Date of Purchase"]),
    batch: csColIndex(zHead, ["Batch Number Orient", "Batch"]),
    desc:  csColIndex(zHead, ["Description"]),
    div:   csColIndex(zHead, ["Division"]),
    name:  csColIndex(zHead, ["Name"]),
  };
  if (zc.so < 0) throw new Error("ZCS04: couldn't find Service Order column.");

  // build ZCS lookup by service order
  const zmap = {};
  for (let r = zh + 1; r < za.length; r++) {
    const so = csNorm(za[r][zc.so]);
    if (so && !(so in zmap)) zmap[so] = za[r];
  }

  // walk VON, clean + join
  const verified = [], errors = [];
  for (let r = vh + 1; r < va.length; r++) {
    const row = va[r] || [];
    const order = csNorm(row[vc.order]);
    const mv = csNorm(row[vc.mv]);
    if (!order || !/^\d+$/.test(order)) continue;     // blank/subtotal rows
    if (mv === "601") continue;                        // drop 601 movements
    if (order.startsWith("4")) continue;               // drop orders starting with 4
    if (mv !== "961" && mv !== "962") continue;        // keep CS replacement movements

    const part = row[vc.part] ?? "";
    const z = zmap[order];
    const notif = z ? csNorm(z[zc.notif]) : "";
    const nd = z ? csToDate(z[zc.ndate]) : null;
    const pd = z ? csToDate(z[zc.pdate]) : null;
    const batch = z ? (z[zc.batch] ?? "") : "";
    const zdesc = z ? (z[zc.desc] ?? "") : "";
    const div = z ? (z[zc.div] ?? "") : "";
    const name = z ? (z[zc.name] ?? "") : "";
    const diff = (nd && pd) ? Math.round((nd - pd) / 86400000) : null;
    const [wy, wlabel] = csWarranty(part);
    const exceeds = (diff !== null && diff > wy * 365);

    // derived columns first, then the full VON row (minus its own Order col)
    const rec = {
      "Order":        order,
      "Notification": notif,
      "Notif Date":   csFmtDate(nd),
      "DOP":          csFmtDate(pd),
      "Diff":         diff === null ? "" : diff,
      "Batch #":      String(batch ?? "").trim(),
      "Description":  String(zdesc ?? "").trim(),
      "Division":     String(div ?? "").trim(),
      "Name":         String(name ?? "").trim(),
    };
    vHeaders.forEach((h, idx) => {
      if (h === "Order") return;          // already at front, don't duplicate
      rec[h] = csCell(row[idx]);
    });
    rec._exceeds = exceeds;               // internal flag only (not a visible column)
    verified.push(rec);

    if (!CS._cols) CS._cols = [...CS_DERIVED_COLS, ...vHeaders.filter(h => h !== "Order")];

    // error collection
    const errs = [];
    if (!z) errs.push("No matching ZCS04 service order");
    if (z && !nd) errs.push("Notification date blank/error");
    if (z && !pd) errs.push("Purchase date blank/error");
    const b = String(batch ?? "").trim();
    if (!b || b.toLowerCase() === "nan") errs.push("Blank batch number");
    if (errs.length) {
      const erec = { "Issue(s)": errs.join("; "), ...rec };
      delete erec._exceeds;
      errors.push(erec);
    }
  }

  const exceptions = verified.filter(v => v._exceeds);
  const cols = CS._cols || [...CS_DERIVED_COLS, ...vHeaders.filter(h => h !== "Order")];
  CS.result = {
    verified, exceptions, errors,
    cols,
    errorCols: ["Issue(s)", ...cols],
    summary:
      `${verified.length} part movement(s) verified (961/962, orders not starting with 4, 601 dropped). ` +
      `${exceptions.length} warranty exception(s) — age beyond the part's warranty. ` +
      `${errors.length} row(s) flagged in the Errors section.`,
  };
}

function csRenderTabs() {
  const r = CS.result;
  const tabs = [
    ["verified",   `Verified (${r.verified.length})`],
    ["exceptions", `Warranty Exceptions (${r.exceptions.length})`],
    ["errors",     `Errors (${r.errors.length})`],
  ];
  const $t = $("#csTabs").empty();
  tabs.forEach(([k, label]) =>
    $t.append(`<button class="tab-btn ${k === CS.activeTab ? "active" : ""}" data-cstab="${k}"
        style="color:${k===CS.activeTab?'#ffd84d':'#cfe1f5'};border-bottom:2px solid ${k===CS.activeTab?'#ffd84d':'transparent'};
               padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;">${label}</button>`));
  $t.off("click").on("click", ".tab-btn", function () {
    CS.activeTab = $(this).data("cstab");
    csRenderTabs(); csRenderTable();
  });
}

function csRenderTable() {
  const r = CS.result;
  let rows, cols;
  if (CS.activeTab === "errors") {
    rows = r.errors;
    cols = r.errorCols;
  } else {
    rows = CS.activeTab === "exceptions" ? r.exceptions : r.verified;
    cols = r.cols;
  }
  const $c = $("#csResultsTable").empty();
  if (!rows.length) { $c.html('<div class="p-4 text-muted italic">No rows.</div>'); return; }
  const $tbl = $('<table class="w-full text-sm border-collapse"></table>');
  $tbl.append(`<thead><tr>${cols.map(c =>
    `<th class="text-left px-3 py-2 font-semibold whitespace-nowrap">${c}</th>`).join("")}</tr></thead>`);
  const $tb = $("<tbody></tbody>");
  rows.forEach((row, i) => {
    const flagged = row._exceeds;
    const rowCls = flagged ? "bg-red-50" : (i % 2 ? "row-odd" : "row-even");
    $tb.append(`<tr class="${rowCls}">${cols.map(col => {
      let v = row[col];
      const num = (col === "Diff" || col === "Qty");
      return `<td class="px-3 py-1.5 ${num ? "text-right" : ""}">${$("<div/>").text(v ?? "").html()}</td>`;
    }).join("")}</tr>`);
  });
  $tbl.append($tb);
  $c.append($tbl);
}

function csRenderResults() {
  $("#csResultsCard").removeClass("hidden");
  if (typeof revealNow==="function") revealNow("#csResultsCard");
  $("#csSummary").text(CS.result.summary);
  CS.activeTab = "verified";
  csRenderTabs();
  csRenderTable();
}

async function csLoad(slot, file, badge) {
  try {
    const buf = await file.arrayBuffer();
    const wb = XLSX.read(buf, { cellDates: true });
    const ws = wb.Sheets[wb.SheetNames[0]];
    CS[slot] = XLSX.utils.sheet_to_json(ws, { header: 1, defval: null });
    $(badge).text("📄  " + file.name);
    $("#csRunBtn").prop("disabled", !(CS.von && CS.zcs));
    $("#csExportMain, #csExportErrors, #csExportWarranty").prop("disabled", true);
    $("#csResultsCard").addClass("hidden");
  } catch (err) { console.error(err); alert("Failed to read file: " + err.message); }
}

$("#csVonInput").on("change", e => { if (e.target.files[0]) csLoad("von", e.target.files[0], "#csVonBadge"); });
$("#csZcsInput").on("change", e => { if (e.target.files[0]) csLoad("zcs", e.target.files[0], "#csZcsBadge"); });

$("#csRunBtn").on("click", function () {
  try {
    runCsVerification();
    csRenderResults();
    $("#csExportMain, #csExportErrors, #csExportWarranty").prop("disabled", false);
  } catch (e) { console.error(e); alert("Verification failed: " + e.message); }
});

const csStrip = arr => arr.map(o => { const c = { ...o }; delete c._exceeds; return c; });
function csStamp() { return new Date().toISOString().replace(/[-T:.Z]/g, "").slice(0, 12); }
function csDownload(rows, cols, sheetName, fileName) {
  const wb = XLSX.utils.book_new();
  const data = rows.length ? rows : [{ [cols[0]]: "(none)" }];
  XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(data, { header: cols }), sheetName);
  XLSX.writeFile(wb, fileName);
}

// 1. VON + ZCS04 embedded, 601 & orders starting with 4 removed
$("#csExportMain").on("click", function () {
  if (!CS.result) return;
  csDownload(csStrip(CS.result.verified), CS.result.cols, "VON+ZCS04", `VON_ZCS04_cleaned_${csStamp()}.xlsx`);
});
// 2. Errors only
$("#csExportErrors").on("click", function () {
  if (!CS.result) return;
  csDownload(csStrip(CS.result.errors), CS.result.errorCols, "Errors", `CS_Errors_${csStamp()}.xlsx`);
});
// 3. Out of warranty only
$("#csExportWarranty").on("click", function () {
  if (!CS.result) return;
  csDownload(csStrip(CS.result.exceptions), CS.result.cols, "Out of Warranty", `CS_Out_of_Warranty_${csStamp()}.xlsx`);
});

$(function () {
  applyRoute();
  $("#introBtn").on("click", () =>
    $("#introModal").removeClass("hidden").addClass("flex"));
  $("#introClose").on("click", () =>
    $("#introModal").addClass("hidden").removeClass("flex"));
  $("#introModal").on("click", e => {
    if (e.target.id === "introModal")
      $("#introModal").addClass("hidden").removeClass("flex");
  });
});

// ---------------- live particles ----------------
(function spawnParticles() {
  const fx = document.getElementById("bg-fx");
  if (!fx || !window.matchMedia("(prefers-reduced-motion: no-preference)").matches) return;
  const N = 26;
  for (let i = 0; i < N; i++) {
    const p = document.createElement("div");
    p.className = "particle";
    const dur = 14 + Math.random() * 22;
    p.style.left = (Math.random() * 100) + "vw";
    p.style.bottom = "-10px";
    p.style.animationDuration = dur + "s";
    p.style.animationDelay = (-Math.random() * dur) + "s";
    p.style.opacity = (0.2 + Math.random() * 0.4).toFixed(2);
    const s = (1 + Math.random() * 2.5).toFixed(1);
    p.style.width = p.style.height = s + "px";
    fx.appendChild(p);
  }
})();

// ---------------- magnetic tilt on tiles ----------------
if (window.matchMedia("(prefers-reduced-motion: no-preference)").matches) {
  document.addEventListener("mousemove", (e) => {
    const tile = e.target.closest && e.target.closest(".tile");
    document.querySelectorAll(".tile.tilting").forEach(t => {
      if (t !== tile) { t.style.transform = ""; t.classList.remove("tilting"); }
    });
    if (!tile) return;
    const r = tile.getBoundingClientRect();
    const px = (e.clientX - r.left) / r.width - 0.5;
    const py = (e.clientY - r.top) / r.height - 0.5;
    tile.classList.add("tilting");
    tile.style.transform = `perspective(900px) rotateY(${px * 6}deg) rotateX(${-py * 6}deg) translateY(-4px)`;
  });
  document.addEventListener("mouseleave", () => {
    document.querySelectorAll(".tile.tilting").forEach(t => { t.style.transform = ""; t.classList.remove("tilting"); });
  });
}

// ---------------- loading bar on file reads / runs ----------------
let _lbTimer;
function startLoading() {
  const b = document.getElementById("loadbar"); if (!b) return;
  b.classList.add("on"); b.style.width = "12%";
  requestAnimationFrame(() => { b.style.width = "78%"; });
}
function stopLoading() {
  const b = document.getElementById("loadbar"); if (!b) return;
  b.style.width = "100%";
  clearTimeout(_lbTimer);
  _lbTimer = setTimeout(() => { b.classList.remove("on"); b.style.width = "0"; }, 350);
}
$(document).on("change", 'input[type="file"]', function () {
  startLoading(); setTimeout(stopLoading, 850);
});
$(document).on("click", "#runBtn,#cjRunBtn,#csRunBtn,#expRunBtn", function () {
  startLoading(); setTimeout(stopLoading, 650);
});

// ---------------- count-up numbers inside result summaries ----------------
function animateNumbersIn(sel) {
  const el = typeof sel === "string" ? document.querySelector(sel) : sel;
  if (!el || !el.textContent.trim()) return;
  const text = el.textContent;
  el.innerHTML = text.replace(/\d[\d,]*(\.\d+)?/g, m =>
    `<span class="num" data-to="${m.replace(/,/g,"")}">${m}</span>`);
  el.querySelectorAll(".num").forEach(span => {
    const to = parseFloat(span.dataset.to); if (!isFinite(to)) return;
    const dec = (span.dataset.to.split(".")[1] || "").length;
    const dur = 750, t0 = performance.now();
    const step = (t) => {
      const k = Math.min(1, (t - t0) / dur);
      const v = to * (1 - Math.pow(1 - k, 3));
      span.textContent = v.toLocaleString(undefined, { minimumFractionDigits: dec, maximumFractionDigits: dec });
      if (k < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  });
}
// wrap revealNow so any result summary counts up once when its card appears
if (typeof revealNow === "function") {
  const _revealNow = revealNow;
  revealNow = function (sel) {
    _revealNow(sel);
    const card = typeof sel === "string" ? document.querySelector(sel) : sel;
    if (!card) return;
    setTimeout(() => {
      const sum = card.querySelector("#csSummary, #expSummary, #cjSummary, #resultsNote");
      if (sum) animateNumbersIn(sum);
    }, 60);
  };
}

// ======================= ACCESS GATE (1 free run → signup) =======================
(function () {
  const RUN_BTNS = ["#runBtn", "#cjRunBtn", "#csRunBtn", "#expRunBtn", "#cjToExpenseBtn"];
  const isMember = () => localStorage.getItem("ia_member") === "1";
  const trialUsed = () => localStorage.getItem("ia_trial") === "1";

  function openGate() {
    const g = document.getElementById("gate");
    g.classList.remove("hidden"); g.classList.add("flex");
  }
  function closeGate() {
    const g = document.getElementById("gate");
    g.classList.add("hidden"); g.classList.remove("flex");
  }
  window.__closeGate = closeGate;

  // Block run buttons in capture phase: free once, then require signup
  RUN_BTNS.forEach(sel => {
    const el = document.querySelector(sel);
    if (!el) return;
    el.addEventListener("click", function (e) {
      if (isMember()) return;                 // members: unlimited
      if (trialUsed()) {                       // already used the free run -> gate
        e.preventDefault();
        e.stopImmediatePropagation();
        openGate();
        return;
      }
      // first run is free — consume the trial
      localStorage.setItem("ia_trial", "1");
    }, true);
  });

  // submit signup -> Netlify Forms, then unlock
  const encode = (data) => Object.keys(data)
    .map(k => encodeURIComponent(k) + "=" + encodeURIComponent(data[k])).join("&");

  const form = document.getElementById("gateForm");
  if (form) {
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      if (document.getElementById("gBot").value) return; // honeypot
      const name = document.getElementById("gName").value.trim();
      const email = document.getElementById("gEmail").value.trim();
      const whatsapp = document.getElementById("gWa").value.trim();
      if (!name || !email) return;
      const btn = form.querySelector('button[type="submit"]');
      btn.textContent = "Saving…"; btn.disabled = true;

      const unlock = () => {
        localStorage.setItem("ia_member", "1");
        localStorage.setItem("ia_user", JSON.stringify({ name, email }));
        btn.textContent = "Get Free Access"; btn.disabled = false;
        closeGate();
      };
      // post to Netlify Forms; unlock regardless of network result
      fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: encode({ "form-name": "access", name, email, whatsapp })
      }).then(unlock).catch(unlock);
    });
  }

  const have = document.getElementById("gHave");
  if (have) have.addEventListener("click", function () {
    const email = (document.getElementById("gEmail").value || "").trim();
    if (!email) { document.getElementById("gEmail").focus(); return; }
    localStorage.setItem("ia_member", "1");
    closeGate();
  });

  // click outside to dismiss (still gated until signup)
  const g = document.getElementById("gate");
  if (g) g.addEventListener("click", e => { if (e.target === g) closeGate(); });
})();

