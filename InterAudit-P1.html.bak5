  <!-- ====================== C-GRADE PENDING UPLOAD ====================== -->
  <div id="page-c-grade" class="space-y-6 hidden">

    <div class="flex items-center justify-between flex-wrap gap-3">
      <div class="flex items-center gap-3 text-blue-200/80 text-sm">
        <a href="#/app" class="crumb-link">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
          Workspace
        </a>
        <span class="text-blue-200/40">/</span>
        <span class="text-blue-100">C-grade Pending Upload</span>
      </div>
    </div>

    <section class="glass p-7">
      <div class="flex items-center gap-3 mb-2">
        <div class="gold-bar"></div>
        <span class="text-[11px] uppercase tracking-[0.28em] text-yellow-300/90">Workflow</span>
      </div>
      <div class="flex items-center gap-3 mt-2">
        <h2 class="h-serif text-4xl text-white leading-tight">
          C-grade <span class="italic text-yellow-300">Pending Upload</span>
        </h2>
        <span class="tip tip-sign"
              data-tip="For every 961 offloading there must be a matching 969 upload against the same Reference. Unmatched 961 rows are flagged as the pending-upload list to send to the responsible team.">i</span>
      </div>
    </section>

  <!-- ACTIONS CARD -->
  <section class="glass p-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="gold-bar"></div>
      <h2 class="h-serif text-2xl text-white">Workflow</h2>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <label class="btn-primary cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
        </svg>
        1. Upload Excel
        <input id="fileInput" type="file" accept=".xlsx,.xls" class="hidden" />
      </label>
      <button id="runBtn" class="btn-accent" disabled>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z"/>
        </svg>
        2. Run All Procedures
      </button>
      <button id="exportBtn" class="btn-ghost" disabled>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 10v6m0 0l-3-3m3 3l3-3M5 20h14a2 2 0 002-2v-2H3v2a2 2 0 002 2z"/>
        </svg>
        3. Export Results
      </button>
      <div id="fileBadge" class="ml-auto text-xs text-blue-100/80 bg-white/10 border border-white/15
                                 px-3 py-2 rounded-full backdrop-blur">
        No file loaded
      </div>
    </div>
  </section>

  <!-- SHEETS TABLE CARD -->
  <section class="glass overflow-hidden">
    <div class="px-6 pt-5 pb-3 flex items-center gap-3">
      <div class="gold-bar"></div>
      <h2 class="h-serif text-2xl text-white">Sheets in Workbook</h2>
      <span class="text-xs text-blue-200/70">(double-click a row to see its results)</span>
    </div>
    <div class="px-5 pb-5">
      <div class="data-surface">
        <div class="overflow-auto max-h-[380px] scroll-shadow">
          <table class="w-full text-sm">
            <thead>
              <tr>
                <th class="text-left px-4 py-3">Sheet</th>
                <th class="text-right px-4 py-3">Rows</th>
                <th class="text-left px-4 py-3">Procedure</th>
                <th class="text-left px-4 py-3">Status</th>
                <th class="text-left px-4 py-3">Notes</th>
              </tr>
            </thead>
            <tbody id="sheetsBody">
              <tr><td colspan="5" class="px-4 py-10 text-center text-muted italic">
                Upload a workbook to begin.
              </td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- RESULTS -->
  <section id="resultsCard" class="glass p-6 hidden">
    <div class="flex items-center gap-3 mb-3">
      <div class="gold-bar"></div>
      <h2 class="h-serif text-2xl text-white">Pending C-grade Uploading <span class="text-yellow-300 italic">— Detail</span></h2>
    </div>
    <div id="resultsNote" class="text-sm text-blue-100/90 mb-4 leading-relaxed"></div>
    <div class="data-surface">
      <div id="resultsTable" class="overflow-auto max-h-[520px]"></div>
    </div>
  </section>

  </div><!-- /page-c-grade -->

  <!-- ====================== EXPENSE ANALYSIS ====================== -->
  <div id="page-expense" class="space-y-6 hidden">

    <div class="flex items-center gap-3 text-blue-200/80 text-sm">
      <a href="#/app" class="crumb-link">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Workspace
      </a>
      <span class="text-blue-200/40">/</span>
      <span class="text-blue-100">Expense Analysis</span>
    </div>

    <section class="glass p-7">
      <div class="flex items-center gap-3 mb-2">
        <div class="gold-bar"></div>
        <span class="text-[11px] uppercase tracking-[0.28em] text-yellow-300/90">Workflow · Stage 2</span>
      </div>
      <div class="flex items-center gap-3 mt-2">
        <h2 class="h-serif text-4xl text-white leading-tight">
          Expense <span class="italic text-yellow-300">Analysis</span>
        </h2>
        <span class="tip tip-sign"
              data-tip="Upload the two Stage-1 cleaned FBCJ sheets (current & previous period). Sums amount per GL across both, fills descriptions from the built-in 901-GL reference, and builds the petty-cash comparison — vertical %, difference, % difference and totals.">i</span>
      </div>
    </section>

    <!-- actions -->
    <section class="glass p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="gold-bar"></div>
        <h2 class="h-serif text-2xl text-white">Workflow</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div class="bg-white/5 border border-white/12 rounded-xl p-4">
          <div class="text-[11px] uppercase tracking-widest text-yellow-300/90 mb-2">Current Period — cleaned sheet</div>
          <label class="btn-primary cursor-pointer w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
            </svg>
            Upload Cleaned FBCJ
            <input id="expFileCur" type="file" accept=".xlsx,.xls,.csv" class="hidden" />
          </label>
          <div id="expBadgeCur" class="mt-2 text-xs text-blue-100/70 truncate">No file loaded</div>
        </div>
        <div class="bg-white/5 border border-white/12 rounded-xl p-4">
          <div class="text-[11px] uppercase tracking-widest text-yellow-300/90 mb-2">Previous Period — cleaned sheet</div>
          <label class="btn-primary cursor-pointer w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
            </svg>
            Upload Cleaned FBCJ
            <input id="expFilePrev" type="file" accept=".xlsx,.xls,.csv" class="hidden" />
          </label>
          <div id="expBadgePrev" class="mt-2 text-xs text-blue-100/70 truncate">No file loaded</div>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <label class="text-xs text-blue-100/80">
          <span class="block uppercase tracking-widest text-yellow-300/80 mb-1">Current period label (optional)</span>
          <input id="expLabelCur" type="text" placeholder="e.g. July 01, 2025 to January 31, 2026"
                 class="w-full bg-white/5 border border-white/15 rounded-lg px-3 py-2 text-white placeholder:text-blue-200/40"/>
        </label>
        <label class="text-xs text-blue-100/80">
          <span class="block uppercase tracking-widest text-yellow-300/80 mb-1">Previous period label (optional)</span>
          <input id="expLabelPrev" type="text" placeholder="e.g. July 01, 2024 to January 31, 2025"
                 class="w-full bg-white/5 border border-white/15 rounded-lg px-3 py-2 text-white placeholder:text-blue-200/40"/>
        </label>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="expRunBtn" class="btn-accent" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z"/>
          </svg>
          Run Analysis
        </button>
        <button id="expExportBtn" class="btn-ghost" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 10v6m0 0l-3-3m3 3l3-3M5 20h14a2 2 0 002-2v-2H3v2a2 2 0 002 2z"/>
          </svg>
          Export Template
        </button>
      </div>
    </section>

    <!-- results -->
    <section id="expResultsCard" class="glass p-6 hidden">
      <div class="flex items-center gap-3 mb-3">
        <div class="gold-bar"></div>
        <h2 class="h-serif text-2xl text-white">Petty-cash <span class="italic text-yellow-300">Comparison</span></h2>
      </div>
      <div id="expSummary" class="text-sm text-blue-100/90 mb-4 leading-relaxed"></div>
      <div class="data-surface">
        <div id="expResultsTable" class="overflow-auto max-h-[600px]"></div>
      </div>
    </section>
  </div>

  <!-- ====================== CASH JOURNAL CLEANER ====================== -->
  <div id="page-cash-cleaner" class="space-y-6 hidden">

    <div class="flex items-center gap-3 text-blue-200/80 text-sm">
      <a href="#/app" class="crumb-link">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Workspace
      </a>
      <span class="text-blue-200/40">/</span>
      <span class="text-blue-100">Cash Journal Cleaner — Stage 1</span>
    </div>

    <section class="glass p-7">
      <div class="flex items-center gap-3 mb-2">
        <div class="gold-bar"></div>
        <span class="text-[11px] uppercase tracking-[0.28em] text-yellow-300/90">Workflow · Stage 1</span>
      </div>
      <div class="flex items-center gap-3 mt-2">
        <h2 class="h-serif text-4xl text-white leading-tight">
          Cash Journal <span class="italic text-yellow-300">Cleaner</span>
        </h2>
        <span class="tip tip-sign"
              data-tip="Drop a raw SAP FBCJ export. Finds headers automatically, pairs each document row with its text/amount row, removes empty & invalid lines, and outputs a clean 9-column list with a grand total.">i</span>
        <span class="tip tip-sign"
              data-tip="Procedure: remove top 7 rows & first 2 columns · drop the 2 rows after the document-number row · trim the columns after Posting Date and Doc Date · drop the Receipt column · realign row 2 · remove empty rows/columns · drop 0-amount rows · keep Amount → Cost Center → GL (6-digit) → 2 more · drop rows with empty cost-centre block · subtotal the Amount column.">≣</span>
      </div>
    </section>

    <section class="glass p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="gold-bar"></div>
        <h2 class="h-serif text-2xl text-white">Workflow</h2>
        <span class="text-xs text-blue-200/70">Upload one or two raw files (e.g. two different years)</span>
      </div>

      <!-- two upload slots -->
      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div class="bg-white/5 border border-white/12 rounded-xl p-4">
          <div class="text-[11px] uppercase tracking-widest text-yellow-300/90 mb-2">File 1 (e.g. Current Year)</div>
          <label class="btn-primary cursor-pointer w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
            </svg>
            Upload Raw FBCJ
            <input id="cjFileInput1" type="file" accept=".xlsx,.xls" class="hidden" />
          </label>
          <div id="cjFileBadge1" class="mt-2 text-xs text-blue-100/70 truncate">No file loaded</div>
        </div>

        <div class="bg-white/5 border border-white/12 rounded-xl p-4">
          <div class="text-[11px] uppercase tracking-widest text-yellow-300/90 mb-2">File 2 (e.g. Previous Year) — optional</div>
          <label class="btn-primary cursor-pointer w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
            </svg>
            Upload Raw FBCJ
            <input id="cjFileInput2" type="file" accept=".xlsx,.xls" class="hidden" />
          </label>
          <div id="cjFileBadge2" class="mt-2 text-xs text-blue-100/70 truncate">No file loaded</div>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="cjRunBtn" class="btn-accent" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z"/>
          </svg>
          Clean
        </button>
        <button id="cjExportBtn" class="btn-ghost" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 10v6m0 0l-3-3m3 3l3-3M5 20h14a2 2 0 002-2v-2H3v2a2 2 0 002 2z"/>
          </svg>
          Export Cleaned File(s)
        </button>
      </div>
    </section>

    <section id="cjResultsCard" class="glass p-6 hidden">
      <div class="flex items-center gap-3 mb-3 flex-wrap">
        <div class="gold-bar"></div>
        <h2 class="h-serif text-2xl text-white">Cleaned <span class="italic text-yellow-300">Transactions</span></h2>
        <button id="cjToExpenseBtn" class="btn-primary ml-auto">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l4-4 4 4 5-5"/>
          </svg>
          Run Expense Analysis →
        </button>
      </div>
      <!-- tabs (one per file) -->
      <div id="cjTabs" class="flex gap-1 border-b border-white/15 mb-3"></div>
      <div id="cjSummary" class="text-sm text-blue-100/90 mb-4 leading-relaxed"></div>
      <div class="data-surface">
        <div id="cjResultsTable" class="overflow-auto max-h-[560px]"></div>
      </div>
    </section>
  </div>

  <!-- ====================== CS NOTIFICATIONS VERIFICATION ====================== -->
  <div id="page-cs-notif" class="space-y-6 hidden">

    <div class="flex items-center gap-3 text-blue-200/80 text-sm">
      <a href="#/app" class="crumb-link">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Workspace
      </a>
      <span class="text-blue-200/40">/</span>
      <span class="text-blue-100">CS Notifications Verification</span>
    </div>

    <section class="glass p-7">
      <div class="flex items-center gap-3 mb-2">
        <div class="gold-bar"></div>
        <span class="text-[11px] uppercase tracking-[0.28em] text-yellow-300/90">Workflow</span>
      </div>
      <div class="flex items-center gap-3 mt-2">
        <h2 class="h-serif text-4xl text-white leading-tight">
          CS Notifications <span class="italic text-yellow-300">Verification</span>
        </h2>
        <span class="tip tip-sign"
              data-tip="Keeps only 961/962 movements from VON (MB51), drops 601 movements and orders starting with 4, then matches each Service Order to ZCS04. Computes purchase-to-claim age and flags parts older than their warranty.">i</span>
        <span class="tip tip-sign"
              data-tip="Warranty rules — COMP / Compressor: 10y · WM Motor: 10y · PCB Kit: 4y · Panel & LED Panel: 2y · LED Board: 1y · all other parts & gases: 1y.">⌘</span>
      </div>
    </section>

    <section class="glass p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="gold-bar"></div>
        <h2 class="h-serif text-2xl text-white">Workflow</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div class="bg-white/5 border border-white/12 rounded-xl p-4">
          <div class="text-[11px] uppercase tracking-widest text-yellow-300/90 mb-2">VON — MB51 raw export</div>
          <label class="btn-primary cursor-pointer w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
            </svg>
            Upload VON
            <input id="csVonInput" type="file" accept=".xlsx,.xls" class="hidden" />
          </label>
          <div id="csVonBadge" class="mt-2 text-xs text-blue-100/70 truncate">No file loaded</div>
        </div>
        <div class="bg-white/5 border border-white/12 rounded-xl p-4">
          <div class="text-[11px] uppercase tracking-widest text-yellow-300/90 mb-2">ZCS04 raw export</div>
          <label class="btn-primary cursor-pointer w-full justify-center">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0-12l-4 4m4-4l4 4"/>
            </svg>
            Upload ZCS04
            <input id="csZcsInput" type="file" accept=".xlsx,.xls" class="hidden" />
          </label>
          <div id="csZcsBadge" class="mt-2 text-xs text-blue-100/70 truncate">No file loaded</div>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <button id="csRunBtn" class="btn-accent" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z"/>
          </svg>
          Run Verification
        </button>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-3">
        <span class="text-xs uppercase tracking-widest text-yellow-300/80 w-full sm:w-auto">Downloads:</span>
        <button id="csExportMain" class="btn-primary" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 10v6m0 0l-3-3m3 3l3-3M5 20h14a2 2 0 002-2v-2H3v2a2 2 0 002 2z"/>
          </svg>
          1. VON + ZCS04 (cleaned)
        </button>
        <button id="csExportErrors" class="btn-ghost" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 9v4m0 4h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/>
          </svg>
          2. Errors
        </button>
        <button id="csExportWarranty" class="btn-ghost" disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          3. Out of Warranty
        </button>
      </div>
    </section>

    <!-- result tabs: Verified / Warranty exceptions / Errors -->
    <section id="csResultsCard" class="glass p-6 hidden">
      <div class="flex items-center gap-3 mb-3">
        <div class="gold-bar"></div>
        <h2 class="h-serif text-2xl text-white">Verification <span class="italic text-yellow-300">Result</span></h2>
      </div>
      <div id="csSummary" class="text-sm text-blue-100/90 mb-3 leading-relaxed"></div>
      <div id="csTabs" class="flex gap-1 border-b border-white/15 mb-3 flex-wrap"></div>
      <div class="data-surface">
        <div id="csResultsTable" class="overflow-auto max-h-[600px]"></div>
      </div>
    </section>
  </div>
</main>

<!-- Hidden static form so Netlify detects + collects signups -->
<form name="access" netlify netlify-honeypot="bot-field" hidden>
  <input type="text" name="name" />
  <input type="email" name="email" />
  <input type="text" name="whatsapp" />
  <input type="text" name="bot-field" />
</form>

<!-- ACCESS GATE MODAL -->
<div id="gate" class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
     style="background:rgba(5,10,14,.78); backdrop-filter:blur(6px);">
  <div class="w-full max-w-md rounded-2xl overflow-hidden"
       style="background:linear-gradient(160deg,#0e2630,#0a161c); border:1px solid rgba(22,168,173,.35); box-shadow:0 40px 100px -40px rgba(0,0,0,.9);">
    <div class="px-7 pt-7">
      <div class="flex items-center gap-3 mb-3">
        <div class="gold-bar w-8"></div>
        <span class="text-[11px] uppercase tracking-[0.28em]" style="color:#3fd0d4;">Full Access</span>
      </div>
      <h3 class="h-serif text-2xl" style="color:#fff;">You've used your free run.</h3>
      <p class="text-sm mt-2" style="color:#9fb1bb;">
        Sign up once for unlimited access to all InterAudit P-1 workflows. It's free.
      </p>
    </div>
    <form id="gateForm" class="px-7 py-6 space-y-3">
      <input id="gName" type="text" required placeholder="Your name"
        class="w-full rounded-lg px-4 py-3 text-sm outline-none"
        style="background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.14); color:#fff;" />
      <input id="gEmail" type="email" required placeholder="Email address"
        class="w-full rounded-lg px-4 py-3 text-sm outline-none"
        style="background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.14); color:#fff;" />
      <input id="gWa" type="text" placeholder="WhatsApp (optional)"
        class="w-full rounded-lg px-4 py-3 text-sm outline-none"
        style="background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.14); color:#fff;" />
      <input type="text" id="gBot" class="hidden" tabindex="-1" autocomplete="off" />
      <button type="submit" class="btn-primary w-full justify-center text-xs" style="border-radius:12px;">
        Get Free Access
      </button>
      <button type="button" id="gHave" class="w-full text-center text-[11px] uppercase tracking-[0.16em] pt-1"
        style="color:#9fb1bb;">I already signed up</button>
    </form>
  </div>
</div>

<!-- STATUS BAR -->
<footer id="statusBar" class="bg-brandDark text-blue-200 text-xs px-6 py-2">Ready</footer>

<!-- INTRODUCTION MODAL -->
<div id="introModal" class="fixed inset-0 modal-bg hidden items-center justify-center z-50 p-4 sans-pro">
  <div class="intro-shell intro-anim relative w-full max-w-5xl max-h-[94vh] rounded-3xl overflow-hidden
              shadow-[0_50px_120px_-30px_rgba(0,0,0,0.7)] text-white">

    <!-- decorative glows + grid -->
    <div class="intro-glow" style="width:280px;height:280px;top:-80px;left:-60px;background:#ffc400;"></div>
    <div class="intro-glow" style="width:340px;height:340px;bottom:-120px;right:-80px;background:#0a84ff;"></div>
    <div class="absolute inset-0 intro-grid"></div>

    <!-- close -->
    <button id="introClose"
            class="absolute top-4 right-4 z-30 w-10 h-10 rounded-full
                   bg-white/10 hover:bg-white/20 border border-white/15
                   flex items-center justify-center text-2xl leading-none transition">&times;</button>

    <div class="relative z-10 overflow-auto max-h-[94vh]">
      <!-- top label strip -->
      <div class="px-8 pt-7 flex items-center gap-3">
        <div class="gold-bar"></div>
        <div class="text-[11px] uppercase tracking-[0.28em] text-blue-200/90">
          Founder &amp; Product Developer
        </div>
      </div>

      <div class="px-8 pt-3 pb-8 grid md:grid-cols-[300px_1fr] gap-8 items-start">

