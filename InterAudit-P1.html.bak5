      <span style="color:var(--ink);">InterAudit P-1</span>
    </div>

    <section class="glass p-9 overflow-hidden">
      <div class="flex items-center gap-3 mb-5">
        <div class="gold-bar w-10"></div>
        <span class="text-[11px] uppercase tracking-[0.32em] text-yellow-300/90">InterAudit P-1 · Workspace</span>
      </div>
      <h2 class="h-serif leading-[0.95]"
          style="font-size:clamp(2.4rem,6vw,5rem); color:var(--ink);">
        <span class="clip"><span style="--d:.05s">EVERY AUDIT</span></span><br/>
        <span class="clip"><span style="--d:.18s">IS A BLANK</span></span>
        <span class="clip"><span style="--d:.3s; color:var(--muted);">LEDGER.</span></span>
      </h2>
      <p class="reveal text-sm mt-6 max-w-xl" style="--d:.45s; color:var(--ink);">
        Upload · process · review · export — one procedure at a time.
      </p>

      <div class="marquee mt-8 border-t border-b py-3" style="border-color:var(--line)">
        <div class="marquee__track">
          <span class="marquee__item">C-Grade Pending Upload</span>
          <span class="marquee__item">Cash Journal Cleaner</span>
          <span class="marquee__item">Expense Analysis</span>
          <span class="marquee__item">CS Notifications</span>
          <span class="marquee__item">Warranty Verification</span>
          <span class="marquee__item">Reconciliation</span>
          <!-- duplicate for seamless loop -->
          <span class="marquee__item">C-Grade Pending Upload</span>
